# Root build-context excludes. The image is built from ./backend, but this
# keeps the root context lean (and protects against accidental root-context
# builds). Secrets and runtime data must NEVER land in an image layer.

# Node / frontend build artifacts (frontend is built separately; dist is
# served by the backend from a runtime path, not baked in here).
node_modules/
frontend/node_modules/
frontend/dist/

# Runtime data lives on a mounted volume only (/data) — never in the image.
data/

# Python caches and bytecode.
__pycache__/
*.pyc
*.py[cod]
.pytest_cache/
.ruff_cache/

# Secrets only in .env (gitignored) — never in build context.
.env

# VCS and editor / OS noise.
.git/
.gitignore
.DS_Store
